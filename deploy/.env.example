# Domain for Caddy TLS. Use :80 for dev without TLS.
DOMAIN=tracker.yourteam.xyz

# Postgres credentials (used by both the DB container and the API)
POSTGRES_USER=quokka
POSTGRES_PASSWORD=change-me-now
POSTGRES_DB=quokka

# JWT signing secret (rotate invalidates all sessions)
JWT_SECRET=generate-a-long-random-string

# Backup retention in days
BACKUP_RETENTION_DAYS=14
