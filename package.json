{
  "name": "quokka",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Self-hosted experiment tracker for AI training runs.",
  "scripts": {
    "dev:api": "pnpm --filter @quokka/api dev",
    "dev:web": "pnpm --filter @quokka/web dev",
    "dev": "pnpm run --parallel dev:api dev:web",
    "build": "pnpm run --parallel build:api build:web",
    "build:api": "pnpm --filter @quokka/api build",
    "build:web": "pnpm --filter @quokka/web build",
    "test": "pnpm --filter @quokka/api test && pnpm --filter @quokka/web test && PYTHONPATH=packages/sdk-python python3 -m unittest discover -s packages/sdk-python/tests && bash deploy/upgrade/tests/run.sh",
    "test:api": "pnpm --filter @quokka/api test",
    "test:web": "pnpm --filter @quokka/web test",
    "test:sdk": "PYTHONPATH=packages/sdk-python python3 -m unittest discover -s packages/sdk-python/tests",
    "test:upgrade": "bash deploy/upgrade/tests/run.sh",
    "db:migrate": "pnpm --filter @quokka/api db:migrate",
    "db:generate": "pnpm --filter @quokka/api db:generate",
    "db:push": "pnpm --filter @quokka/api db:push"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
